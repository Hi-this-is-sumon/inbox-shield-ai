{
  "manifest_version": 3,
  "name": "Inbox Shield AI",
  "version": "1.1",
  "description": "Detects spam emails in Gmail using a deployed AI backend.",
"homepage_url": "https://inbox-shield-ai-lake.vercel.app/",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": ["https://mail.google.com/*", "http://localhost:8000/*", "https://*.vercel.app/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["https://mail.google.com/*"],
    "js": ["content.js"],
    "css": ["popup.css"]
  }],
  "web_accessible_resources": [{
    "resources": ["assets/*"],
    "matches": ["https://mail.google.com/*"]
  }]
}
